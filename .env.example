# ===== REQUIRED =====
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ===== AI PROVIDER (choose one, set AI_PROVIDER to match) =====

# Option 1: Groq (FREE — fast, recommended — console.groq.com)
AI_PROVIDER=groq
GROQ_API_KEY=your_groq_api_key_here

# Option 2: Gemini (FREE with Google AI Studio — aistudio.google.com)
# AI_PROVIDER=gemini
# GEMINI_API_KEY=your_gemini_api_key_here

# Option 3: OpenAI / ChatGPT (paid — platform.openai.com)
# AI_PROVIDER=openai
# OPENAI_API_KEY=your_openai_api_key_here

# Option 4: OpenRouter (paid, very cheap — openrouter.ai)
# AI_PROVIDER=openrouter
# AI_INTEGRATIONS_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# AI_INTEGRATIONS_OPENROUTER_API_KEY=your_openrouter_api_key_here
